# ---- Upvex backend (copy to backend/.env) ----

APP_ENV=development
CORS_ORIGINS=http://localhost:5173

# Database: local docker-compose Postgres by default.
# For Supabase, use the connection string from Project Settings > Database
# (replace postgresql:// with postgresql+asyncpg:// and use the session pooler on port 5432):
# DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+asyncpg://upvex:upvex@localhost:5432/upvex

# Supabase Auth (Project Settings > API)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Legacy JWT secret (Project Settings > API > JWT Settings). If empty, JWKS is used.
SUPABASE_JWT_SECRET=

# Local development without a Supabase project: bypass auth as a local admin user.
# NEVER enable in production.
DEV_AUTH_BYPASS=true

# Celery / Redis
REDIS_URL=redis://localhost:6379/0
# Run tasks inline without a worker (handy in dev; set false when running a real worker)
CELERY_TASK_ALWAYS_EAGER=true

# OpenRouter (https://openrouter.ai/keys). Empty key = stub lessons in dev.
OPENROUTER_API_KEY=
MODEL_LESSON_GENERATION=anthropic/claude-sonnet-4.5
MODEL_QUIZ_GENERATION=anthropic/claude-sonnet-4.5
MODEL_DIAGNOSTIC_EVALUATOR=openai/gpt-4.1-mini

# ---- Upvex frontend (copy to frontend/.env) ----
# VITE_API_URL=http://localhost:8000
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
