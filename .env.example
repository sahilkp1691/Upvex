# ---- Upvex backend (copy to backend/.env) ----

APP_ENV=development
CORS_ORIGINS=http://localhost:5173

# Database: local docker-compose Postgres by default.
# For Supabase beta/prod, copy the Session pooler URI from Connect → Direct → Session pooler
# (IPv4). Replace postgresql:// with postgresql+asyncpg://. Host may be aws-0-… or aws-1-…:
# DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+asyncpg://upvex:upvex@localhost:5432/upvex

# Supabase Auth (Project Settings > API). Use the project root URL (no /rest/v1 suffix).
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Legacy JWT secret (Project Settings > API > JWT Settings). Prefer empty + JWKS for new projects.
SUPABASE_JWT_SECRET=

# Local development without a Supabase project: bypass auth as a local admin user.
# NEVER enable for beta/production against real Supabase Auth.
DEV_AUTH_BYPASS=true

# Celery / Redis
REDIS_URL=redis://localhost:6379/0
# Run tasks inline without a worker (handy in dev; set false when running a real worker)
CELERY_TASK_ALWAYS_EAGER=true

# OpenRouter (https://openrouter.ai/keys). Empty key = stub lessons in dev.
OPENROUTER_API_KEY=
MODEL_LESSON_GENERATION=anthropic/claude-sonnet-4.5
MODEL_QUIZ_GENERATION=anthropic/claude-sonnet-4.5
MODEL_DIAGNOSTIC_EVALUATOR=openai/gpt-4.1-mini

# ---- Upvex frontend (copy to frontend/.env) ----
# VITE_API_URL=http://localhost:8000
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
#
# Supabase Auth (Dashboard > Authentication):
# - Enable Confirm email under Providers > Email
# - Site URL: http://localhost:5173 (or your production URL)
# - Redirect URLs: http://localhost:5173/** and your production /** URL
# - Custom SMTP (e.g. Resend) for sending confirmation emails to any address
# - Signup uses a 6-digit OTP, not a magic link. In Authentication > Emails >
#   "Confirm signup" template, use the {{ .Token }} variable (the 6-digit code)
#   instead of {{ .ConfirmationURL }}. Example body:
#     Your Upvex verification code is {{ .Token }}
